# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_api_key_here

# Agent (defaults match voice_receptionist.py)
ELEVENLABS_AGENT_ID=agent_1101ksg1sptafcz9ny805h8y82p1
ELEVENLABS_BRANCH_ID=agtbrch_8801ksg1sqwmf8rabcd8qy30jw29

# true = fetch conversation token from backend (private agent)
# false = connect with agent ID only (public agent, auth disabled in dashboard)
ELEVENLABS_REQUIRES_AUTH=true

# Post-call webhook — ElevenAgents settings (NOT Settings → API Webhooks)
# https://elevenlabs.io/app/agents/settings
# URL: https://YOUR-NGROK-OR-HOST/webhooks/elevenlabs — enable post_call_transcription
# Docs: https://elevenlabs.io/docs/eleven-agents/workflows/post-call-webhooks
ELEVENLABS_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase — Project Settings → API (use service_role on server only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email notification after each call
NOTIFY_EMAIL_TO=chestergarett@gmail.com
# Resend (recommended): https://resend.com — verify your domain or use onboarding@resend.dev for tests
RESEND_API_KEY=re_your_resend_key
NOTIFY_EMAIL_FROM=Chester AI <onboarding@resend.dev>

# Or SMTP (Gmail app password, etc.) — used if RESEND_API_KEY is empty
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Local dev defaults; production = your Cloud Run frontend URL (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Google Cloud Run (deploy scripts) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-west1
CLOUD_RUN_SERVICE_BACKEND=virtual-assistant-api
CLOUD_RUN_SERVICE_FRONTEND=virtual-assistant-web
# Set automatically by ./scripts/deploy-backend.sh
VITE_API_BASE=
BACKEND_URL=
FRONTEND_URL=
